@startuml AirconModule_and_WallPanel_Architecture

package "apiModule" {
  class AirconFactory {
    +getAirconditionerImplementation(device: Device): AirconditionerController
    +getAirconditionerImplementations(): AirconditionerController[]
  }

  class PolarbearFactory {
    +getPolarbearImplementation(acpanel: AcPanel, deviceRepository: DeviceRepository, airconFactory: AirconFactory, logger: Logger): Ipolarbear
  }

  class Main {
    -airconFactory: AirconFactory
    -polarbearFactory: PolarbearFactory
    -polarbearCode: number
    +updateAircoPanel(polarbearCode): Promise<void>
    +updateAircoData(): Promise<void>
  }
}

package "domotics/airconModule" {
  interface AirconditionerController {
    +setTemperature(airconditioner, newTemperature): Promise<Airconditioner>
    +getTemperature(airconditioner): Promise<Airconditioner>
    +setFanSpeed(airconditioner, newFanSpeed): Promise<Airconditioner>
    +getFanSpeed(airconditioner): Promise<Airconditioner>
    +getAllData(airconditioner): Promise<Airconditioner>
    +getDeviceId(): String
  }

  class CondariaControllerImpl
  class HeinEnHopmanControllerImpl
  class HeinEnHopmanGooilandControllerImpl
  class HeinEnHopmanIpControllerImpl
  class JohnsonAcControllerImpl
  class VecoControllerImpl
}

package "domotics/wallPanel" {
  interface Ipolarbear {
    +updateAcPanels(airconditioners): Airconditioner[]
    +getDeviceId(): String
  }

  class "PolarbearController (v1)" as PolarbearControllerV1 {
    -connection: any
    -deviceRepository: DeviceRepository
    -airconFactory: AirconFactory
    +updateAcPanels(acpanel, airconditioners): Airconditioner[]
    +closeConnection(): void
  }

  class "PolarbearController (v2/v3)" as PolarbearControllerV2 implements Ipolarbear {
    -connection: any
    -acpanel: AcPanel
    -deviceRepository: DeviceRepository
    -airconFactory: AirconFactory
    -logger: Logger
    +updateAcPanels(airconditioners): Airconditioner[]
    +getDeviceId(): String
    +closeConnection(): void
  }
}

package "entities" {
  class Device {
    +id: string
    +type: string
    +name: string
    +bidirectional: boolean
  }

  class Airconditioner {
    +maxTemperature: number
    +minTemperature: number
    +maxSetTemperature: number
    +minSetTemperature: number
    +setTemperature: number
    +currentTemperature: number
    +currentFanspeed: number
    +maxFanspeed: number
    +minFanspeed: number
    +data: any
  }

  class AcPanel {
    +id: String
    +ip: String
    +type: String
    +port: String
    +ids: String[]
  }
}

package "database" {
  class DeviceRepository {
    +getDeviceById(id): Promise
  }
}

package "libraries" {
  class Logger
  class "modbus-rtu" as ModbusRtu {
    +createRtuMessage(...)
    +decodeRtuResponse(...)
  }
}

Airconditioner --|> Device

CondariaControllerImpl ..|> AirconditionerController
HeinEnHopmanControllerImpl ..|> AirconditionerController
HeinEnHopmanGooilandControllerImpl ..|> AirconditionerController
HeinEnHopmanIpControllerImpl ..|> AirconditionerController
JohnsonAcControllerImpl ..|> AirconditionerController
VecoControllerImpl ..|> AirconditionerController

AirconFactory --> AirconditionerController
AirconFactory --> Device

PolarbearFactory --> Ipolarbear
PolarbearFactory --> AirconFactory
PolarbearFactory --> DeviceRepository
PolarbearFactory --> Logger

PolarbearControllerV1 --> DeviceRepository
PolarbearControllerV1 --> AirconFactory
PolarbearControllerV1 --> Airconditioner
PolarbearControllerV1 --> AirconditionerController
PolarbearControllerV1 --> ModbusRtu

PolarbearControllerV2 --> AcPanel
PolarbearControllerV2 --> DeviceRepository
PolarbearControllerV2 --> AirconFactory
PolarbearControllerV2 --> Airconditioner
PolarbearControllerV2 --> AirconditionerController
PolarbearControllerV2 --> Logger
PolarbearControllerV2 --> ModbusRtu

AirconditionerController --> Airconditioner

Main --> AirconFactory
Main --> PolarbearFactory
Main --> PolarbearControllerV1

@enduml
